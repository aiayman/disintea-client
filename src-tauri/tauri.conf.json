{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disintea",
  "version": "1.0.5",
  "identifier": "com.ayman.disintea-client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Disintea",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxNzc0MjdCN0VCQ0JDMzkKUldRNXZMeCtlMEozc1hzdHlibEtiNjdxYi9ERFlXVE4weExpT2NIbVc3L0N0aENjMlcxaElCWjkK",
      "endpoints": [
        "https://github.com/aiayman/disintea-client/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
